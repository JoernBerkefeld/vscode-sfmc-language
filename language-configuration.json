{
    "comments": {
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["%%[", "]%%"],
        ["%%=", "=%%"],
        ["{{", "}}"],
        ["(", ")"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        { "open": "%%[", "close": "]%%" },
        { "open": "%%=", "close": "=%%" },
        { "open": "{{", "close": "}}" },
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" },
        { "open": "/*", "close": "*/" }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["{{", "}}"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*(%%\\[|<script\\b[^>]*language\\s*=\\s*[\"']ampscript|if\\b|for\\b)",
            "end": "^\\s*(\\]%%|</script>|endif\\b|next\\b)"
        }
    },
    "wordPattern": "@?[a-zA-Z_][a-zA-Z0-9_]*"
}
